[sub_resource type="GDScript" id="GDScript_lbu1t"]
script/source = "extends CollisionPolygon2D;
class_name CollisionPolygonEx;

#region signals

#endregion

#region fields
# Collision shape resource
@export var convexPolygonShape: ConvexPolygonShape2D = null;
#endregion

#region methods
func _ready() -> void:
	if convexPolygonShape != null:
		apply_shape();

func apply_shape() -> void:
	polygon = convexPolygonShape.points;

func set_shape(shape: ConvexPolygonShape2D) -> void:
	convexPolygonShape = shape;
	apply_shape();
#endregion
"

